{
  "manifest_version": 3,
  "name": "Acuity Chrome Extension",
  "version": "1.0.0",
  "description": "A Chrome extension built with React and Vite",
  "background": {
    "service_worker": "src/utils/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Acuity Extension"
  },
  "permissions": ["storage", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.reddit.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' http://localhost:4200; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.reddit.com/*"
      ],
      "js": ["src/utils/content-worker.ts"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["assets/*"],
      "use_dynamic_url": false
    }
  ]
}
